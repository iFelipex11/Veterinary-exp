@page "/edituser"
@inject IRepository Repository
@inject SweetAlertService SweetAlertService
@inject NavigationManager NavigationManager
@inject ILoginService LoginService

@if (user is null)
{
    <div class="spinner"></div>
}
else
{
    <EditForm Model="user" OnValidSubmit="SaveUserAsync">
        <DataAnnotationsValidator />

        <div class="auth-shell">
            <div class="auth-card auth-card-wide">
                <div class="auth-header">
                    <h3>Editar perfil</h3>
                    <p>Actualiza tus datos personales y manten tu cuenta al dia.</p>
                </div>

                <div class="profile-photo-panel">
                    @if (!string.IsNullOrWhiteSpace(user.Photo))
                    {
                        <img class="profile-photo-preview" src="@user.Photo" alt="Foto de perfil" />
                    }
                    else
                    {
                        <div class="profile-photo-placeholder">@GetInitials()</div>
                    }

                    <div class="profile-photo-copy">
                        <strong>@user.FullName</strong>
                        <span>@user.Email</span>
                    </div>
                </div>

                <div class="row g-4">
                    <div class="col-md-6">
                        <div class="mb-3">
                            <label class="form-label">Nombres</label>
                            <InputText class="form-control" @bind-Value="user.FirstName" />
                            <ValidationMessage For="@(() => user.FirstName)" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Apellidos</label>
                            <InputText class="form-control" @bind-Value="user.LastName" />
                            <ValidationMessage For="@(() => user.LastName)" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Documento</label>
                            <InputText class="form-control" @bind-Value="user.Document" />
                            <ValidationMessage For="@(() => user.Document)" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Direccion</label>
                            <InputText class="form-control" @bind-Value="user.Address" />
                            <ValidationMessage For="@(() => user.Address)" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Telefono</label>
                            <InputText class="form-control" @bind-Value="user.PhoneNumber" />
                            <ValidationMessage For="@(() => user.PhoneNumber)" />
                        </div>
                    </div>

                    <div class="col-md-6">
                        <div class="mb-3">
                            <label class="form-label">Pais</label>
                            <select class="form-select" value="@selectedCountryId" @onchange="CountryChangedAsync">
                                <option value="0">-- Seleccione un pais --</option>
                                @if (countries is not null)
                                {
                                    @foreach (var country in countries)
                                    {
                                        <option value="@country.Id">@country.Name</option>
                                    }
                                }
                            </select>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Estado/Departamento</label>
                            <select class="form-select" value="@selectedStateId" @onchange="StateChangedAsync">
                                <option value="0">-- Seleccione un estado/departamento --</option>
                                @if (states is not null)
                                {
                                    @foreach (var state in states)
                                    {
                                        <option value="@state.Id">@state.Name</option>
                                    }
                                }
                            </select>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Ciudad</label>
                            <select class="form-select" @bind="user.CityId">
                                <option value="0">-- Seleccione una ciudad --</option>
                                @if (cities is not null)
                                {
                                    @foreach (var city in cities)
                                    {
                                        <option value="@city.Id">@city.Name</option>
                                    }
                                }
                            </select>
                            <ValidationMessage For="@(() => user.CityId)" />
                        </div>
                        <div class="mb-4">
                            <label class="form-label">Foto (URL opcional)</label>
                            <InputText class="form-control" @bind-Value="user.Photo" />
                            <ValidationMessage For="@(() => user.Photo)" />
                        </div>

                        <div class="auth-actions">
                            <button class="btn btn-primary" type="submit">Guardar cambios</button>
                            <a class="btn btn-outline-secondary" href="/changepassword">Cambiar contrasena</a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </EditForm>
}

@code {
    private User? user;
    private List<Country>? countries;
    private List<State>? states;
    private List<City>? cities;
    private int selectedCountryId;
    private int selectedStateId;

    protected override async Task OnInitializedAsync()
    {
        await LoadUserAsync();
    }

    private async Task LoadUserAsync()
    {
        var responseHttp = await Repository.GetAsync<User>("/api/accounts");
        if (responseHttp.Error)
        {
            var messageError = await responseHttp.GetErrorMessageAsync();
            await SweetAlertService.FireAsync("Error", messageError, SweetAlertIcon.Error);
            NavigationManager.NavigateTo("/");
            return;
        }

        user = responseHttp.Response;
        await LoadCountriesAsync();

        if (user?.City?.State is not null)
        {
            selectedCountryId = user.City.State.CountryId;
            selectedStateId = user.City.StateId;
            await LoadStatesAsync(selectedCountryId);
            await LoadCitiesAsync(selectedStateId);
        }
    }

    private async Task SaveUserAsync()
    {
        if (user is null)
        {
            return;
        }

        var responseHttp = await Repository.PutAsync<User, TokenDTO>("/api/accounts", user);
        if (responseHttp.Error)
        {
            var messageError = await responseHttp.GetErrorMessageAsync();
            await SweetAlertService.FireAsync("Error", messageError, SweetAlertIcon.Error);
            return;
        }

        await LoginService.LoginAsync(responseHttp.Response!.Token);
        await SweetAlertService.FireAsync("Exito", "Usuario actualizado correctamente.", SweetAlertIcon.Success);
        NavigationManager.NavigateTo("/");
    }

    private async Task LoadCountriesAsync()
    {
        var responseHttp = await Repository.GetAsync<List<Country>>("/api/countries/combo");
        if (!responseHttp.Error)
        {
            countries = responseHttp.Response;
        }
    }

    private async Task LoadStatesAsync(int countryId)
    {
        if (countryId == 0)
        {
            states = null;
            return;
        }

        var responseHttp = await Repository.GetAsync<List<State>>($"/api/states/combo/{countryId}");
        if (!responseHttp.Error)
        {
            states = responseHttp.Response;
        }
    }

    private async Task LoadCitiesAsync(int stateId)
    {
        if (stateId == 0)
        {
            cities = null;
            return;
        }

        var responseHttp = await Repository.GetAsync<List<City>>($"/api/cities/combo/{stateId}");
        if (!responseHttp.Error)
        {
            cities = responseHttp.Response;
        }
    }

    private async Task CountryChangedAsync(ChangeEventArgs e)
    {
        selectedCountryId = Convert.ToInt32(e.Value);
        selectedStateId = 0;

        if (user is not null)
        {
            user.CityId = 0;
        }

        cities = null;
        await LoadStatesAsync(selectedCountryId);
    }

    private async Task StateChangedAsync(ChangeEventArgs e)
    {
        selectedStateId = Convert.ToInt32(e.Value);

        if (user is not null)
        {
            user.CityId = 0;
        }

        await LoadCitiesAsync(selectedStateId);
    }

    private string GetInitials()
    {
        if (user is null)
        {
            return "VU";
        }

        var first = string.IsNullOrWhiteSpace(user.FirstName) ? "V" : user.FirstName.Trim()[0].ToString().ToUpperInvariant();
        var last = string.IsNullOrWhiteSpace(user.LastName) ? "U" : user.LastName.Trim()[0].ToString().ToUpperInvariant();
        return $"{first}{last}";
    }
}
