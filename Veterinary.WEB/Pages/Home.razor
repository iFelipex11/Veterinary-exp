@page "/"

<PageTitle>Home</PageTitle>

<div class="hero-panel">
    <div class="hero-copy">
        <span class="status-badge status-success">Sistema activo</span>
        <h1>Veterinary</h1>
        <p>Gestiona propietarios, autenticacion y mantenimiento de usuarios desde una sola aplicacion.</p>

        <AuthorizeView>
            <Authorized>
                <p class="hero-note">Sesion iniciada como @context.User.Identity?.Name</p>
            </Authorized>
            <NotAuthorized>
                <p class="hero-note">Inicia sesion o registra una cuenta para comenzar.</p>
            </NotAuthorized>
        </AuthorizeView>
    </div>

    <div class="hero-actions">
        <AuthorizeView Roles="Admin">
            <Authorized>
                <a class="btn btn-primary" href="/owners">Ir a propietarios</a>
            </Authorized>
        </AuthorizeView>
        <AuthorizeView>
            <Authorized>
                <a class="btn btn-outline-secondary" href="/edituser">Mi perfil</a>
            </Authorized>
            <NotAuthorized>
                <a class="btn btn-primary" href="/login">Iniciar sesion</a>
                <a class="btn btn-outline-secondary" href="/register">Crear cuenta</a>
            </NotAuthorized>
        </AuthorizeView>
    </div>
</div>
