@page "/owners"
@attribute [Authorize(Roles = "Admin")]
@inject IRepository Repository
@inject SweetAlertService Swal

<PageTitle>Owners</PageTitle>

<h1>Owners</h1>

<div class="mb-3">
    <a class="btn btn-primary" href="/owners/create">New Owner</a>
</div>

@if (!string.IsNullOrWhiteSpace(ErrorMessage))
{
    <div class="alert alert-danger" role="alert">
        @ErrorMessage
    </div>
}

<GenericList MyList="OwnersList">
    <Body>
        <table class="table table-striped">
            <thead>
                <tr>
                    <th>Document</th>
                    <th>First Name</th>
                    <th>Last Name</th>
                    <th>Fixed Phone</th>
                    <th>Cell Phone</th>
                    <th>Address</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var owner in OwnersList!)
                {
                    <tr>
                        <td>@owner.Document</td>
                        <td>@owner.FirstName</td>
                        <td>@owner.LastName</td>
                        <td>@owner.FixedPhone</td>
                        <td>@owner.CellPhone</td>
                        <td>@owner.Address</td>
                        <td>
                            <a class="btn btn-warning btn-sm me-2" href="@($"/owners/edit/{owner.Id}")">Editar</a>
                            <button class="btn btn-danger btn-sm" @onclick="() => DeleteAsync(owner.Id)">Borrar</button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </Body>
</GenericList>

@code {
    private List<Owner>? OwnersList { get; set; }
    private string? ErrorMessage { get; set; }

    protected override async Task OnInitializedAsync()
    {
        await LoadOwnersAsync();
    }

    private async Task LoadOwnersAsync()
    {
        var responseHttp = await Repository.GetAsync<List<Owner>>("/api/owners");
        if (responseHttp.Error)
        {
            ErrorMessage = await responseHttp.GetErrorMessageAsync();
            OwnersList = [];
            return;
        }

        ErrorMessage = null;
        OwnersList = responseHttp.Response;
    }

    private async Task DeleteAsync(int id)
    {
        var result = await Swal.FireAsync(new SweetAlertOptions
        {
            Title = "Confirmacion",
            Text = "Deseas borrar este owner?",
            Icon = SweetAlertIcon.Warning,
            ShowCancelButton = true,
            ConfirmButtonText = "Si",
            CancelButtonText = "No"
        });

        var confirmed = !string.IsNullOrEmpty(result.Value);
        if (!confirmed)
        {
            return;
        }

        var responseHttp = await Repository.DeleteAsync($"/api/owners/{id}");
        if (responseHttp.Error)
        {
            ErrorMessage = await responseHttp.GetErrorMessageAsync();
            await Swal.FireAsync("Error", ErrorMessage, SweetAlertIcon.Error);
            return;
        }

        await LoadOwnersAsync();
    }
}
